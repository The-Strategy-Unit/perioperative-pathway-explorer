	</model>
	<model name="calcs">
		<variables>
			<aux name="4-hr sessions per week" ai_state="F">
				<eqn>IF TIME &lt;= lead_time
THEN &quot;4-hr_sess_per_week_calib&quot;
ELSE &quot;new_4-hr_sess_per_week&quot;</eqn>
				<units>sessions/week</units>
			</aux>
			<aux name="cases per 4-hr session" ai_state="F" access="output" isee:autocreated="true">
				<eqn>1.99</eqn>
				<scale min="0" max="3"/>
				<range min="0" max="3"/>
				<units>People/session</units>
			</aux>
			<aux name="cap nhs theatre" ai_state="F">
				<eqn>&quot;4-hr_sessions_per_week&quot; * cases_per_sess * &quot;p_o&amp;t_treated_hips_knees&quot; * theatre_effic /7</eqn>
				<units>People</units>
			</aux>
			<aux name="hk rtt with dta" ai_state="F">
				<eqn>&quot;pub_rtt_o&amp;t_dta&quot; * &quot;p_o&amp;t_treated_hips_knees&quot;</eqn>
				<units>People</units>
			</aux>
			<aux name="hk rtt" ai_state="F">
				<eqn>hk_rtt_with_dta / p_dta_pc_rtt</eqn>
				<units>People</units>
			</aux>
			<aux name="ave time waiting\nref to opa (weeks) calib" ai_state="F" access="output" isee:autocreated="true">
				<eqn>22.2207078505707</eqn>
				<units>Weeks</units>
			</aux>
			<aux name="ave time waiting (days)" ai_state="F">
				<eqn>
&quot;ave_time_waiting_ref_to_opa_(weeks)_calib&quot; * 7</eqn>
				<units>Days</units>
			</aux>
			<aux name="calib cap opa" ai_state="F">
				<eqn>hk_wait_for_opa / &quot;ave_time_waiting_(days)&quot;</eqn>
				<units>People</units>
			</aux>
			<aux name="hk wait for opa" ai_state="F">
				<eqn>hk_rtt - hk_rtt_with_dta</eqn>
				<units>People</units>
			</aux>
			<aux name="init delay" ai_state="F" access="output">
				<eqn>37</eqn>
				<units>People</units>
			</aux>
			<aux name="init i wait opa" ai_state="F" access="output">
				<eqn>init_wait_opa * early_screening</eqn>
				<units>People</units>
			</aux>
			<aux name="init s wait opa" ai_state="F" access="output">
				<eqn>init_wait_opa - init_i_wait_opa</eqn>
				<units>People</units>
			</aux>
			<aux name="init i wait opt" ai_state="F" access="output">
				<eqn>init_wait_opt * early_screening</eqn>
				<units>People</units>
			</aux>
			<aux name="init s wait opt" ai_state="F" access="output">
				<eqn>(init_wait_opt - init_i_wait_opt)</eqn>
				<units>People</units>
			</aux>
			<aux name="init i wait admit" ai_state="F" access="output">
				<eqn>init_wait_admit * early_screening</eqn>
				<units>People</units>
			</aux>
			<aux name="init s wait poa" ai_state="F" access="output">
				<eqn>init_wait_poa - init_i_wait_poa</eqn>
				<units>People</units>
			</aux>
			<aux name="init treat" ai_state="F" access="output">
				<eqn>463</eqn>
				<units>People</units>
			</aux>
			<aux name="init wait opa" ai_state="F">
				<eqn>INIT(&quot;der_rtt_h&amp;k_wait_opa&quot;)</eqn>
				<units>People</units>
			</aux>
			<aux name="init wait poa" ai_state="F">
				<eqn>INIT(&quot;der_rtt_h&amp;k_dta&quot;) - INIT(init_wait_admit) - INIT(init_wait_opt)</eqn>
				<units>People</units>
			</aux>
			<aux name="init wait admit" ai_state="F">
				<eqn>INIT(&quot;der_rtt_h&amp;k_dta&quot;) *.94</eqn>
				<units>People</units>
			</aux>
			<aux name="init wait opt" ai_state="F">
				<eqn>INIT(&quot;der_rtt_h&amp;k_dta&quot;) * 0.045</eqn>
				<units>People</units>
			</aux>
			<aux name="init s wait admit" ai_state="F" access="output">
				<eqn>init_wait_admit - init_i_wait_admit</eqn>
				<units>People</units>
			</aux>
			<aux name="pc early screening" ai_state="F" access="input">
				<eqn>40</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="dropout rate" ai_state="F" access="output" isee:autocreated="true">
				<eqn>-LN(1 - p_preadm_dropout) /( &quot;time_in_tci_(weeks)&quot; * 7)</eqn>
				<units>1/Days</units>
			</aux>
			<aux name="p preadm dropout" ai_state="F" access="output">
				<eqn>0.125344561279985</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="time in tci (weeks)" ai_state="F">
				<eqn>9.62868899450401</eqn>
				<units>Days</units>
			</aux>
			<aux name="ave time dta to treat (weeks)" ai_state="F" access="input">
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>Weeks</units>
			</aux>
			<stock name="population" ai_state="F">
				<eqn>init_pop_18_2025</eqn>
				<inflow>annual_change</inflow>
				<non_negative/>
				<units>People</units>
			</stock>
			<flow name="annual change" ai_state="F">
				<eqn>population * pop_18_growth_rate_pa / 365</eqn>
				<non_negative/>
				<units>People/Days</units>
			</flow>
			<aux name="pop 18 growth rate pa" ai_state="F">
				<eqn>0.00814978742476</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="init pop 18 2025" ai_state="F">
				<eqn>47233159</eqn>
				<units>People</units>
			</aux>
			<aux name="referrals per day" ai_state="F" access="output">
				<eqn>referrals_per_year / 365</eqn>
				<units>People/Days</units>
			</aux>
			<aux name="referrals per year" ai_state="F">
				<eqn>population * referral_rate_per_10th / 10000</eqn>
				<units>People/Years</units>
			</aux>
			<aux name="o&amp;t referral rate p 10th pa" ai_state="F">
				<eqn>320</eqn>
				<units>Per Year</units>
			</aux>
