				<eqn>der_cum_stops_no_admit + der_hips_knees_cum_stops_admit + der_cum_stops_with_dta_no_treat</eqn>
				<units>People</units>
			</aux>
			<aux name="theatre effic" ai_state="F">
				<eqn>IF TIME &gt; lead_time
THEN (pc_theatre_efficiency/100)
ELSE th_eff_calib</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="cases per sess" ai_state="F">
				<eqn>IF TIME &gt; lead_time
THEN &quot;cases_per_4-hr_session&quot;
ELSE cases_per_sess_calib</eqn>
				<units>People/session</units>
			</aux>
			<aux name="early screening" ai_state="F" access="output">
				<eqn>IF TIME &gt; lead_time 
THEN pc_early_screening/100
ELSE 0.4</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="p dta pc rtt" ai_state="F">
				<eqn>IF sw_alt_dta_pc_rtt = 0
THEN &quot;pub_rtt_o&amp;t_dta&quot; / &quot;pub_rtt_o&amp;t_all&quot;
ELSE p_alt_dta_pc_rtt</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="der rtt h&amp;k wait opa" ai_state="F">
				<eqn>&quot;der_rtt_h&amp;k&quot; - &quot;der_rtt_h&amp;k_dta&quot;</eqn>
				<units>People</units>
			</aux>
			<aux name="sw alt dta pc rtt" ai_state="F">
				<eqn>0</eqn>
				<format precision="1"/>
				<scale min="0" max="1"/>
				<range min="0" max="1"/>
				<units>dmnl</units>
			</aux>
			<aux name="p alt dta pc rtt" ai_state="F">
				<eqn>.2</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="p theatre private init" ai_state="F">
				<eqn>.33</eqn>
				<scale min="0" max="1"/>
				<range min="0" max="1"/>
				<units>dmnl</units>
			</aux>
			<aux name="theatre cases pd" ai_state="F" access="output">
