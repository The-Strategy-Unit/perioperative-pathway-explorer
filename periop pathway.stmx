				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>People/Days</units>
			</aux>
			<stock name="monthly new dtas" ai_state="F">
				<eqn>INIT(new_dta)</eqn>
				<inflow>new_dta_in</inflow>
				<outflow>new_dta_out</outflow>
				<conveyor force_leak_fraction="true">
					<len>30.5</len>
				</conveyor>
				<units>People/Days</units>
			</stock>
			<flow name="new dta in" ai_state="F">
				<eqn>new_dta</eqn>
				<non_negative/>
				<units>People/Days/Days</units>
			</flow>
			<flow name="new dta out" ai_state="F">
				<eqn>0</eqn>
				<non_negative/>
				<units>People/Days/Days</units>
			</flow>
			<aux name="new o&amp;t opa per week" ai_state="F">
				<eqn>29350</eqn>
				<units>People</units>
			</aux>
			<aux name="theatre cases per month" ai_state="F">
				<eqn>theatre_cases_pd * 30.5</eqn>
				<units>People</units>
			</aux>
			<aux name="wlmds cum stops with dta no treat" ai_state="F">
				<eqn>TIME</eqn>
				<gf>
					<yscale min="0" max="100"/>
					<xpts>31,59,90,120,151,181,212,243,273,304,334,365</xpts>
					<ypts>43,67,62,58,84,291,271,268,284,315,309,205</ypts>
				</gf>
				<units>People</units>
			</aux>
			<aux name="der cum stops with dta no treat" ai_state="F">
				<eqn>wlmds_cum_stops_with_dta_no_treat * &quot;p_o&amp;t_treated_hips_knees&quot;</eqn>
				<units>People</units>
			</aux>
			<aux name="clock stops no treat no dta" ai_state="F" access="input">
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>People/Days</units>
			</aux>
			<stock name="monthly stops\ndta no treatment" ai_state="F">
				<eqn>INIT(der_cum_stops_with_dta_no_treat)</eqn>
				<inflow>stops_dta_no_treat_in</inflow>
				<outflow>stops_dta_no_treat_out</outflow>
				<conveyor>
					<len>30.5</len>
				</conveyor>
				<units>People</units>
			</stock>
			<flow name="stops dta no treat in" ai_state="F">
				<eqn>clock_stops_dta_no_treat</eqn>
				<non_negative/>
				<units>People/Days</units>
			</flow>
			<flow name="stops dta no treat out" ai_state="F">
				<eqn>0</eqn>
				<non_negative/>
				<units>People/Days</units>
			</flow>
			<aux name="clock stops dta no treat" ai_state="F" access="input">
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>People/Days</units>
			</aux>
			<aux name="opa demand" ai_state="F" access="input">
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>People</units>
			</aux>
			<aux name="private cases per week" ai_state="F">
				<eqn>priv_theatre_cases * 7</eqn>
				<units>People</units>
			</aux>
			<aux name="nhs cases per week" ai_state="F">
				<eqn>cap_nhs_theatre * 7</eqn>
				<units>People</units>
			</aux>
			<aux name="p rate" ai_state="F">
				<eqn>1 - EXP(-calib_dropout_rate * &quot;ave_time_dta_to_treat_(weeks)&quot; * 7)</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="pc dropout rate" ai_state="F">
				<eqn>p_rate * 100</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="Year" ai_state="F">
				<eqn>INT(TIME/365.25) + 2025</eqn>
				<format precision="1" scale_by="1"/>
			</aux>
			<aux name="Month" ai_state="F">
				<eqn>INT((TIME MOD 365) / 30.5) + 1</eqn>
				<format isee:extender="Months"/>
			</aux>
			<aux name="new opa per week" ai_state="F">
				<eqn>&quot;new_o&amp;t_opa_per_week&quot; * p_refs_to_hips_knees</eqn>
			</aux>
		</variables>
