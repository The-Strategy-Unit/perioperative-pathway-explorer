				<eqn>&quot;pub_rtt_o&amp;t_dta&quot; * &quot;p_o&amp;t_treated_hips_knees&quot;</eqn>
				<units>People</units>
			</aux>
			<aux name="der rtt h&amp;k" ai_state="F">
				<eqn>&quot;der_rtt_h&amp;k_dta&quot; / p_dta_pc_rtt</eqn>
				<units>People</units>
			</aux>
			<aux name="wlmds flow new rtt" ai_state="F">
				<eqn>TIME</eqn>
				<gf>
