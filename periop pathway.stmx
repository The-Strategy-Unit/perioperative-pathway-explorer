			<isee:payoff_element name="calcs.monthly_stops_treatment" weight="0.00000420168865233759" compare_name="calcs.der_hips_knees_cum_stops_admit" compare_run="-2" tolerance="0" type="ls"/>
			<isee:payoff_element name="calcs.monthly_stops_dta_no_treatment" weight="0.00101890666488244" compare_name="calcs.der_cum_stops_with_dta_no_treat" compare_run="-2" tolerance="0" type="ls"/>
		</isee:payoff_specs>
