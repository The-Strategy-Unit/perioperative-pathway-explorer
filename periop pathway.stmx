			<isee:payoff_element name="calcs.referrals_per_day" weight="0.0000167861191810874" compare_name="calcs.wlmds_flow_new_rtt" compare_run="-2" tolerance="0" type="ls"/>
			<isee:payoff_element name="total_in_pathway" weight="8.70403071315452e-8" compare_name='calcs."der_rtt_h&amp;k"' compare_run="-2" tolerance="0" type="ls"/>
			<isee:payoff_element name="calcs.monthly_referrals" weight="6.70400732182612e-7" compare_name="calcs.der_cum_new_rtt" compare_run="-2" tolerance="0" type="ls"/>
