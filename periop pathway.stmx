	<model_units>
		<unit name="Dimensionless">
			<eqn>1</eqn>
			<alias>dmnl</alias>
			<alias>unitless</alias>
			<alias>fraction</alias>
		</unit>
		<unit name="People">
			<eqn/>
			<alias>person</alias>
			<alias>persons</alias>
		</unit>
		<unit name="Days">
			<eqn/>
			<alias>day</alias>
		</unit>
		<unit name="Weeks">
			<eqn/>
			<alias>wk</alias>
			<alias>week</alias>
		</unit>
	</model_units>
	<model>
		<variables>
			<stock name="i wait opa" ai_state="F">
				<eqn>calcs.init_i_wait_opa</eqn>
				<inflow>i_referrals</inflow>
				<outflow>i_do_not_proceed_surgery</outflow>
				<outflow>i_opa_to_poa</outflow>
				<outflow>i_fasttrack_to_admit</outflow>
				<non_negative/>
				<units>People</units>
			</stock>
			<stock name="s wait opa" ai_state="F">
				<eqn>calcs.init_s_wait_opa</eqn>
				<inflow>s_referrals</inflow>
				<outflow>s_do_not_proceed_surgery</outflow>
				<outflow>s_opa_to_tci</outflow>
				<non_negative/>
				<units>People</units>
			</stock>
			<stock name="i wait poa" ai_state="F">
				<eqn>calcs.init_i_wait_poa</eqn>
				<inflow>i_opt_to_poa</inflow>
				<inflow>i_opa_to_poa</inflow>
				<outflow>i_poa_to_ready</outflow>
				<outflow>i_poa_to_opt</outflow>
				<non_negative/>
				<units>People</units>
			</stock>
			<stock name="i wait opt" ai_state="F">
				<eqn>calcs.init_i_wait_opt</eqn>
				<inflow>i_poa_to_opt</inflow>
				<outflow>i_opt_to_poa</outflow>
				<outflow>i_opt_to_ready</outflow>
				<non_negative/>
				<units>People</units>
			</stock>
			<stock name="i wait with tci" ai_state="F">
				<eqn>calcs.init_i_wait_admit</eqn>
				<inflow>i_poa_to_ready</inflow>
				<inflow>i_opt_to_ready</inflow>
				<inflow>i_fasttrack_to_admit</inflow>
				<outflow>i_admit</outflow>
				<outflow>i_preadmit_dropout</outflow>
				<non_negative/>
				<units>People</units>
			</stock>
			<stock name="s tci wait poa" ai_state="F">
				<eqn>calcs.init_s_wait_poa</eqn>
				<inflow>s_opa_to_tci</inflow>
				<outflow>s_poa_to_opt</outflow>
				<outflow>s_poa_to_ready</outflow>
				<non_negative/>
				<units>People</units>
			</stock>
			<stock name="s wait opt" ai_state="F">
				<eqn>calcs.init_s_wait_opt</eqn>
				<inflow>s_poa_to_opt</inflow>
				<outflow>s_opt_to_ready</outflow>
				<non_negative/>
				<units>People</units>
			</stock>
			<stock name="surgery and recovery" ai_state="F">
				<eqn>calcs.init_treat</eqn>
				<inflow>s_admit</inflow>
				<inflow>i_admit</inflow>
				<outflow>same_day_cancellation_need_reopt</outflow>
				<outflow>timely_discharge</outflow>
				<outflow>medically_fit_but_delayed</outflow>
				<non_negative/>
				<units>People</units>
			</stock>
			<flow name="i admit" ai_state="F">
				<eqn>IF surg_demand &gt; 0 
THEN MIN(i_wait_with_tci,  cap_theatre) * (i_wait_with_tci / surg_demand)
ELSE 0</eqn>
				<non_negative/>
				<units>People/Days</units>
			</flow>
			<flow name="referrals" ai_state="F">
				<eqn>referrals_per_day * p_refs_to_hips_knees</eqn>
				<non_negative/>
				<units>People/Days</units>
			</flow>
			<flow name="i referrals" ai_state="F">
				<eqn>referrals * early_screening</eqn>
				<non_negative/>
				<units>People/Days</units>
			</flow>
			<flow name="s referrals" ai_state="F" access="output">
				<eqn>referrals * (1 - early_screening)</eqn>
				<non_negative/>
				<units>People/Days</units>
			</flow>
			<flow name="i poa to ready" ai_state="F">
				<eqn>IF poa_demand &gt; 0
THEN MIN(i_wait_poa,  cap_poa) * (i_wait_poa / poa_demand) * (1 - p_i_unfit)
ELSE 0</eqn>
				<non_negative/>
				<units>People/Days</units>
			</flow>
			<flow name="i poa to opt" ai_state="F">
				<eqn>IF poa_demand &gt; 0
THEN MIN(i_wait_poa,  cap_poa) * (i_wait_poa / poa_demand) * ( p_i_unfit)
ELSE 0</eqn>
				<non_negative/>
				<units>People/Days</units>
			</flow>
			<flow name="i opt to ready" ai_state="F">
				<eqn>(i_wait_opt / opt_time) * (1 - p_i_re_poa)</eqn>
				<non_negative/>
				<units>People/Days</units>
			</flow>
			<flow name="s opa to tci" ai_state="F">
				<eqn>IF opa_demand &gt; 0
THEN MIN(s_wait_opa,  cap_opa) * (s_wait_opa / opa_demand) * (1- p_non_surgery)
ELSE 0</eqn>
				<non_negative/>
				<units>People/Days</units>
			</flow>
			<flow name="s poa to opt" ai_state="F">
				<eqn>IF poa_demand &gt; 0
THEN MIN(s_tci_wait_poa,  cap_poa) * (s_tci_wait_poa / poa_demand) * ( p_s_unfit)
ELSE 0</eqn>
				<non_negative/>
				<units>People/Days</units>
			</flow>
			<flow name="s opt to ready" ai_state="F">
				<eqn>s_wait_opt / opt_time</eqn>
				<non_negative/>
				<units>People/Days</units>
			</flow>
			<stock name="s wait post poa" ai_state="F">
				<eqn>calcs.init_s_wait_admit</eqn>
				<inflow>s_poa_to_ready</inflow>
				<inflow>s_opt_to_ready</inflow>
				<inflow>s_reopt</inflow>
				<outflow>s_admit</outflow>
				<outflow>s_preadmit_dropout</outflow>
				<non_negative/>
				<units>People</units>
			</stock>
			<flow name="s poa to ready" ai_state="F">
				<eqn>IF poa_demand &gt; 0
THEN MIN(s_tci_wait_poa,  cap_poa) * (s_tci_wait_poa / poa_demand) * (1 -  p_s_unfit)
ELSE 0</eqn>
				<non_negative/>
				<units>People/Days</units>
			</flow>
			<flow name="s admit" ai_state="F">
				<eqn>IF surg_demand &gt; 0 
THEN MIN(s_wait_post_poa,  cap_theatre) * (s_wait_post_poa / surg_demand)
ELSE 0</eqn>
				<non_negative/>
				<units>People/Days</units>
			</flow>
			<aux name="cap poa" ai_state="F">
				<eqn>10000</eqn>
				<units>People</units>
			</aux>
			<aux name="p s unfit" ai_state="F">
				<eqn>.4</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="poa demand" ai_state="F">
				<eqn>i_wait_poa + s_tci_wait_poa</eqn>
				<units>People</units>
			</aux>
			<aux name="p i re poa" ai_state="F">
				<eqn>.2</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="opt demand" ai_state="F">
				<eqn>i_wait_opt + s_wait_opt</eqn>
				<units>People</units>
			</aux>
			<flow name="i opt to poa" ai_state="F">
				<eqn>(i_wait_opt / opt_time) * p_i_re_poa</eqn>
				<non_negative/>
				<units>People/Days</units>
			</flow>
			<flow name="s do not proceed surgery" ai_state="F">
				<eqn>IF opa_demand &gt; 0
THEN MIN(s_wait_opa,  cap_opa) * (s_wait_opa / opa_demand)  * p_non_surgery
ELSE 0</eqn>
				<non_negative/>
				<units>People/Days</units>
			</flow>
			<flow name="i do not proceed surgery" ai_state="F">
				<eqn>IF opa_demand &gt; 0
THEN MIN(i_wait_opa,  cap_opa) * (i_wait_opa / opa_demand) * p_non_surgery
ELSE 0</eqn>
				<non_negative/>
				<units>People/Days</units>
			</flow>
			<aux name="p non surgery" ai_state="F">
				<eqn>0.555082247666873</eqn>
				<units>dmnl</units>
			</aux>
			<flow name="medically fit but delayed" ai_state="F">
				<eqn>medically_fit * delay_fraction</eqn>
				<non_negative/>
				<units>People/Days</units>
			</flow>
			<stock name="delayed discharge" ai_state="F">
				<eqn>calcs.init_delay</eqn>
				<inflow>medically_fit_but_delayed</inflow>
				<outflow>supported_discharge</outflow>
				<non_negative/>
				<units>People</units>
			</stock>
			<flow name="timely discharge" ai_state="F">
				<eqn>medically_fit * (1 - delay_fraction)</eqn>
				<non_negative/>
				<units>People/Days</units>
			</flow>
			<flow name="supported discharge" ai_state="F">
				<eqn>delayed_discharge / delay_los</eqn>
				<non_negative/>
				<units>People/Days</units>
			</flow>
			<aux name="s treatment los" ai_state="F">
				<eqn>1.5</eqn>
				<units>Days</units>
			</aux>
			<aux name="treatment los" ai_state="F">
				<eqn>new_treatment_los * early_screening_1 + 
((1 - early_screening_1) * s_treatment_los)</eqn>
				<units>Days</units>
			</aux>
			<aux name="discharge support effect" ai_state="F">
				<eqn>1</eqn>
				<scale min="0" max="1"/>
				<range min="0" max="1"/>
				<units>dmnl</units>
			</aux>
			<aux name="new treatment los" ai_state="F">
				<eqn>s_treatment_los - screening_reduction_in_los</eqn>
				<units>Days</units>
			</aux>
			<aux name="screening reduction in los" ai_state="F">
				<eqn>s_treatment_los - i_early_screening_los</eqn>
				<units>Days</units>
			</aux>
			<flow name="same day cancellation need reopt" ai_state="F">
				<eqn>s_admit * s_cancel_reopt_rate</eqn>
				<non_negative/>
				<units>People/Days</units>
			</flow>
			<aux name="s cancel reopt rate" ai_state="F">
				<eqn>.1</eqn>
				<scale min="0" max="1"/>
				<range min="0" max="1"/>
				<units>dmnl</units>
			</aux>
			<aux name="opt time" ai_state="F">
				<eqn>42</eqn>
				<units>Days</units>
			</aux>
			<aux name="clock stops" ai_state="F" access="output">
				<eqn>i_preadmit_dropout + s_preadmit_dropout + timely_discharge + supported_discharge + s_do_not_proceed_surgery + i_do_not_proceed_surgery</eqn>
				<isee:summing/>
				<units>People/Days</units>
			</aux>
			<flow name="i fasttrack to admit" ai_state="F">
				<eqn>IF opa_demand &gt; 0
THEN MIN(i_wait_opa,  cap_opa) * (i_wait_opa / opa_demand) * p_fasttrack * (1 - p_non_surgery)
ELSE 0</eqn>
				<non_negative/>
				<units>People/Days</units>
			</flow>
			<aux name="p fasttrack" ai_state="F">
				<eqn>.2</eqn>
				<units>dmnl</units>
			</aux>
			<flow name="i opa to poa" ai_state="F">
				<eqn>IF opa_demand &gt; 0
THEN MIN(i_wait_opa,  cap_opa) * (i_wait_opa / opa_demand) * (1 - p_fasttrack) * (1 - p_non_surgery)
ELSE 0</eqn>
				<non_negative/>
				<units>People/Days</units>
			</flow>
			<aux name="activity per day (admissions less late cancel)" ai_state="F">
				<eqn>i_admit + s_admit - same_day_cancellation_need_reopt</eqn>
				<isee:summing/>
				<units>People/Days</units>
			</aux>
			<aux name="in hospital" ai_state="F">
				<eqn>surgery_and_recovery + delayed_discharge</eqn>
				<isee:summing/>
				<units>People</units>
			</aux>
			<aux name="total waiting" ai_state="F">
				<eqn>s_wait_opa + s_tci_wait_poa + s_wait_opt + s_wait_post_poa + i_wait_opa + i_wait_poa + i_wait_opt + i_wait_with_tci</eqn>
				<isee:summing/>
				<units>People</units>
			</aux>
			<aux name="delay los" ai_state="F">
				<eqn>(improved_delay_los * discharge_support_effect/100) + 
(base_delay_los * (1 - discharge_support_effect/100))</eqn>
				<units>Days</units>
			</aux>
			<aux name="delay fraction" ai_state="F">
				<eqn>0.03 + (.12 * (1 - early_screening_1) * (1 - (discharge_support_effect/100)))</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="medically fit" ai_state="F">
				<eqn>surgery_and_recovery / treatment_los</eqn>
				<units>People/Days</units>
			</aux>
			<flow name="s reopt" ai_state="F">
				<eqn>same_day_cancellation_need_reopt</eqn>
				<non_negative/>
				<units>People/Days</units>
			</flow>
			<aux name="i early screening los" ai_state="F">
				<eqn>0.5</eqn>
				<units>Days</units>
			</aux>
			<aux name="clock stops no treatment all" ai_state="F" isee:derived_units="true">
				<eqn>s_do_not_proceed_surgery + i_do_not_proceed_surgery + s_preadmit_dropout + i_preadmit_dropout</eqn>
				<isee:summing/>
				<units>People/Days</units>
			</aux>
			<flow name="s preadmit dropout" ai_state="F">
				<eqn>s_wait_post_poa * dropout_rate_alt</eqn>
				<non_negative/>
				<units>People/Days</units>
			</flow>
			<flow name="i preadmit dropout" ai_state="F">
				<eqn>dropout_rate_alt * i_wait_with_tci</eqn>
				<non_negative/>
				<units>People/Days</units>
			</flow>
			<aux name="waiting with dta" ai_state="F">
				<eqn>i_waiting_with_dta + s_waiting_with_dta</eqn>
				<isee:summing/>
				<units>People</units>
			</aux>
			<aux name="s waiting with dta" ai_state="F" isee:derived_units="true">
				<eqn>s_tci_wait_poa + s_wait_opt + s_wait_post_poa</eqn>
				<isee:summing/>
				<units>People</units>
			</aux>
			<aux name="i waiting with dta" ai_state="F" isee:derived_units="true">
				<eqn>i_wait_opt + i_wait_poa + i_wait_with_tci</eqn>
				<isee:summing/>
				<units>People</units>
			</aux>
			<aux name="p refs to hips knees" ai_state="F" access="output">
				<eqn>0.189</eqn>
				<format precision="0.001"/>
				<scale min="0" max="1"/>
				<range min="0" max="1"/>
				<units>dmnl</units>
			</aux>
			<module name="calcs" isee:label="" ai_state="F">
				<connect to='."ave_time_ref_to_opa_(weeks)"' from='calcs."ave_time_ref_to_opa_(weeks)"'/>
				<connect2 to='"ave_time_ref_to_opa_(weeks)"' from='calcs."ave_time_ref_to_opa_(weeks)"'/>
				<connect to=".dropout_rate_alt" from="calcs.calib_dropout_rate"/>
				<connect2 to="dropout_rate_alt" from="calcs.calib_dropout_rate"/>
				<connect to=".cap_opa" from="calcs.cap_opa"/>
				<connect2 to="cap_opa" from="calcs.cap_opa"/>
				<connect to='."cases_per_4-hr_session"' from='calcs."cases_per_4-hr_session"'/>
				<connect2 to='"cases_per_4-hr_session"' from='calcs."cases_per_4-hr_session"'/>
				<connect to=".dropout_rate" from="calcs.dropout_rate"/>
				<connect2 to="dropout_rate" from="calcs.dropout_rate"/>
				<connect to=".early_screening" from="calcs.early_screening"/>
				<connect2 to="early_screening" from="calcs.early_screening"/>
				<connect to=".early_screening_1" from="calcs.early_screening"/>
				<connect2 to="early_screening_1" from="calcs.early_screening"/>
				<connect to=".lead_time" from="calcs.lead_time"/>
				<connect2 to="lead_time" from="calcs.lead_time"/>
				<connect to=".referrals_per_day" from="calcs.referrals_per_day"/>
				<connect2 to="referrals_per_day" from="calcs.referrals_per_day"/>
				<connect to=".cap_theatre" from="calcs.theatre_cases_pd"/>
				<connect2 to="cap_theatre" from="calcs.theatre_cases_pd"/>
				<connect to="calcs.admit" from=".admit"/>
				<connect2 to="calcs.admit" from="admit"/>
				<connect to='calcs."ave_time_dta_to_treat_(weeks)"' from='."ave_time_dta_to_treat_(weeks)"'/>
				<connect2 to='calcs."ave_time_dta_to_treat_(weeks)"' from='"ave_time_dta_to_treat_(weeks)"'/>
				<connect to="calcs.clock_stops" from=".clock_stops"/>
				<connect2 to="calcs.clock_stops" from="clock_stops"/>
				<connect to="calcs.clock_stops_dta_no_treat" from=".clock_stops_dta_no_treat"/>
				<connect2 to="calcs.clock_stops_dta_no_treat" from="clock_stops_dta_no_treat"/>
				<connect to="calcs.clock_stops_no_treat_no_dta" from=".clock_stops_no_treat_no_dta"/>
				<connect2 to="calcs.clock_stops_no_treat_no_dta" from="clock_stops_no_treat_no_dta"/>
				<connect to="calcs.new_dta" from=".new_dta"/>
				<connect2 to="calcs.new_dta" from="new_dta"/>
				<connect to="calcs.opa_demand" from=".opa_demand"/>
				<connect2 to="calcs.opa_demand" from="opa_demand"/>
				<connect to="calcs.p_refs_to_hips_knees" from=".p_refs_to_hips_knees"/>
				<connect2 to="calcs.p_refs_to_hips_knees" from="p_refs_to_hips_knees"/>
				<connect to="calcs.pc_early_screening" from=".pc_early_screening"/>
				<connect2 to="calcs.pc_early_screening" from="pc_early_screening"/>
				<connect to="calcs.referrals" from=".referrals"/>
				<connect2 to="calcs.referrals" from="referrals"/>
				<connect to="calcs.treated" from=".treated"/>
				<connect2 to="calcs.treated" from="treated"/>
			</module>
			<aux name="opa demand" ai_state="F" isee:derived_units="true">
				<eqn>i_wait_opa + s_wait_opa</eqn>
				<isee:summing/>
				<units>People</units>
			</aux>
			<aux name="admit" ai_state="F" isee:derived_units="true">
				<eqn>i_admit + s_admit</eqn>
				<isee:summing/>
				<units>People/Days</units>
			</aux>
			<aux name="surg demand" ai_state="F" isee:derived_units="true">
				<eqn>i_wait_with_tci + s_wait_post_poa</eqn>
				<isee:summing/>
				<units>People</units>
			</aux>
			<aux name="dropout rate" ai_state="F" access="input">
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>1/Days</units>
			</aux>
			<aux name="s in pathway" ai_state="F" isee:derived_units="true">
				<eqn>s_tci_wait_poa + s_wait_opa + s_wait_opt + s_wait_post_poa</eqn>
				<isee:summing/>
				<units>People</units>
			</aux>
			<aux name="i in pathway" ai_state="F" isee:derived_units="true">
				<eqn>i_wait_opa + i_wait_opt + i_wait_poa + i_wait_with_tci</eqn>
				<isee:summing/>
				<units>People</units>
			</aux>
			<aux name="total in pathway" ai_state="F">
				<eqn>i_in_pathway + s_in_pathway</eqn>
				<isee:summing/>
				<units>People</units>
			</aux>
			<aux name="ave time rtt (weeks)" ai_state="F">
				<eqn>&quot;ave_time_ref_to_opa_(weeks)&quot; + &quot;ave_time_dta_to_treat_(weeks)&quot;</eqn>
				<units>Weeks</units>
			</aux>
			<aux name="ave time dta to treat (weeks)" ai_state="F" access="output">
				<eqn>IF admit &gt; 0
THEN waiting_with_dta / admit /7
ELSE 0</eqn>
				<units>Weeks</units>
			</aux>
			<aux name="referrals per day" ai_state="F" access="input">
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>People/Days</units>
			</aux>
			<aux name="preadm drops" ai_state="F" isee:derived_units="true">
				<eqn>s_preadmit_dropout + i_preadmit_dropout</eqn>
				<isee:summing/>
				<units>People/Days</units>
			</aux>
			<aux name="cases per 4-hr session" ai_state="F" access="input">
				<eqn>1.5</eqn>
				<units>People/session</units>
			</aux>
			<aux name="treated" ai_state="F" isee:derived_units="true" access="output">
				<eqn>timely_discharge + supported_discharge</eqn>
				<isee:summing/>
				<units>People/Days</units>
			</aux>
			<aux name="dropout rate alt" ai_state="F" access="input">
				<eqn>0.002</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="pc early screening" ai_state="F" access="output">
				<eqn>40</eqn>
				<scale min="0" max="100"/>
				<range min="0" max="100"/>
				<units>dmnl</units>
			</aux>
			<aux name="early screening" ai_state="F" access="input">
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="cap theatre" ai_state="F" access="input">
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>People</units>
			</aux>
			<aux name="i clock stops no treatment" ai_state="F" isee:derived_units="true" access="output">
				<eqn>i_do_not_proceed_surgery + i_preadmit_dropout</eqn>
				<isee:summing/>
				<units>People/Days</units>
			</aux>
			<aux name="s clock stops no treatment" ai_state="F" isee:derived_units="true" access="output">
				<eqn>s_do_not_proceed_surgery + s_preadmit_dropout</eqn>
				<isee:summing/>
				<units>People/Days</units>
			</aux>
			<aux name="lead time" ai_state="F" access="input">
				<eqn>366</eqn>
				<units>Days</units>
			</aux>
			<aux name="early screening 1" ai_state="F" access="input">
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="cap opa" ai_state="F" access="input">
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>People</units>
			</aux>
			<aux name="ave time ref to opa (weeks)" ai_state="F" access="input">
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="p i unfit" ai_state="F">
				<eqn>.25</eqn>
				<scale min="0" max="1"/>
				<range min="0" max="1"/>
				<units>dmnl</units>
			</aux>
			<aux name="new dta" ai_state="F" isee:derived_units="true">
				<eqn>s_opa_to_tci + i_opa_to_poa</eqn>
				<isee:summing/>
				<units>People/Days</units>
			</aux>
			<aux name="base delay los" ai_state="F">
				<eqn>1</eqn>
				<units>Days</units>
			</aux>
			<aux name="improved delay los" ai_state="F">
				<eqn>0.4</eqn>
				<units>Days</units>
			</aux>
			<aux name="clock stops dta no treat" ai_state="F" isee:derived_units="true" access="output">
				<eqn>s_preadmit_dropout + i_preadmit_dropout</eqn>
				<isee:summing/>
				<units>People/Days</units>
			</aux>
			<aux name="clock stops no treat no dta" ai_state="F" isee:derived_units="true" access="output">
				<eqn>s_do_not_proceed_surgery + i_do_not_proceed_surgery</eqn>
				<isee:summing/>
				<units>People/Days</units>
			</aux>
		</variables>
